// This is Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

/// Defines the role of a user within the platform.
enum Role {
  FARMER
  BUYER
  DRIVER
  ADMIN
  SUPERADMIN
}

/// Represents the lifecycle status of an order.
enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

/// The method chosen by the buyer to pay for the order.
enum PaymentMethod {
  CASH_ON_DELIVERY
  DIGITAL
}

/// The current state of a payment transaction.
enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

/// Represents the lifecycle status of a delivery.
enum DeliveryStatus {
  UNASSIGNED
  ASSIGNED
  PICKED_UP
  EN_ROUTE
  DELIVERED
  FAILED
}

/// Status of a dispute raised by a user.
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

/// Status of cash reconciliation for drivers handling COD orders.
enum ReconciliationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Status of a system report.
enum ReportStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

/// Represents a user account on the platform.
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  phone         String   @unique
  fullName      String
  role          Role
  address       String?  // General address
  latitude      Float?
  longitude     Float?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  profile         UserProfile?
  farmerProfile   FarmerProfile?
  products        Product[]
  orders          Order[]              @relation("BuyerOrders")
  deliveries      Delivery[]           @relation("DriverDeliveries")
  disputes        Dispute[]            @relation("UserDisputes")
  reconciliations CashReconciliation[] @relation("DriverReconciliations")
  reviewsGiven    Review[]             @relation("ReviewerReviews")
  reviewsReceived Review[]             @relation("TargetReviews")
  reportsFiled    Report[]             @relation("ReporterReports")
  reportsAgainst  Report[]             @relation("ReportedUserReports")
  notifications   Notification[]
  otpVerifications OTPVerification[]
}

/// Extended profile information for general users.
model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  avatarUrl   String?
  bio         String?
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Specialized profile information for farmers.
model FarmerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  farmName       String
  farmSize       Float?   // in acres or hectares
  isOrganic      Boolean  @default(false)
  certifications String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Represents a category for grouping products.
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

/// Represents a product listed by a farmer.
model Product {
  id          String      @id @default(uuid())
  farmerId    String
  categoryId  String
  name        String
  description String
  price       Decimal     @db.Decimal(10, 2)
  unit        String      // e.g. kg, liter, piece
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  farmer      User        @relation(fields: [farmerId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  images      ProductImage[]
  reviews     Review[]
}

/// Dedicated model for product images.
model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/// Represents a customer order.
model Order {
  id              String        @id @default(uuid())
  buyerId         String
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING) // Kept for quick access, but detailed in Payment
  deliveryAddress String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  buyer           User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  items           OrderItem[]
  delivery        Delivery?
  disputes        Dispute[]
  payment         Payment?
}

/// Represents an individual item within an order.
model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  priceAtBuy Decimal  @db.Decimal(10, 2) // Lock in price at purchase time

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
}

/// Detailed payment information for an order.
model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  gatewayTxId   String?       // Transaction ID from payment gateway
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

/// Represents the delivery assignment for an order.
model Delivery {
  id               String         @id @default(uuid())
  orderId          String         @unique
  driverId         String?
  status           DeliveryStatus @default(UNASSIGNED)
  cashCollected    Decimal?       @db.Decimal(10, 2) // Important for COD
  pickupTime       DateTime?
  dropoffTime      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver           User?          @relation("DriverDeliveries", fields: [driverId], references: [id])
  logs             DeliveryLog[]
}

/// Tracks the status history of a delivery.
model DeliveryLog {
  id          String         @id @default(uuid())
  deliveryId  String
  status      DeliveryStatus
  notes       String?
  createdAt   DateTime       @default(now())

  delivery    Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

/// Manages cash reconciliation for drivers after COD deliveries.
model CashReconciliation {
  id               String               @id @default(uuid())
  driverId         String
  amount           Decimal              @db.Decimal(10, 2)
  status           ReconciliationStatus @default(PENDING)
  notes            String?
  remittedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  driver           User                 @relation("DriverReconciliations", fields: [driverId], references: [id])
}

/// Represents a dispute raised for an order.
model Dispute {
  id          String        @id @default(uuid())
  orderId     String
  userId      String        // User who raised the dispute
  reason      String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order       Order         @relation(fields: [orderId], references: [id])
  user        User          @relation("UserDisputes", fields: [userId], references: [id])
}

/// A review given by a buyer for a product or a user (farmer/driver).
model Review {
  id          String   @id @default(uuid())
  reviewerId  String
  targetId    String?  // Can be a User ID (farmer/driver)
  productId   String?  // Can be a Product ID
  rating      Int      // 1 to 5
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviewer    User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  targetUser  User?    @relation("TargetReviews", fields: [targetId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
}

/// A report submitted against a user or entity for rule violations.
model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String?
  reason         String
  status         ReportStatus @default(OPEN)
  resolution     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reporter       User         @relation("ReporterReports", fields: [reporterId], references: [id])
  reportedUser   User?        @relation("ReportedUserReports", fields: [reportedUserId], references: [id])
}

/// A notification meant for a specific user.
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   // e.g., ORDER_UPDATE, SYSTEM, PROMO
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Secure storage for OTP codes used during authentication and verification.
model OTPVerification {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
